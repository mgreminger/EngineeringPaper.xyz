{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "engineering-paper",
  "compatibility_date": "2026-03-26",
  "main": "src/database/_worker.ts",
  "assets": {
    "directory": "dist",
    "binding": "ASSETS"
  },
  "kv_namespaces": [
    {
      "binding": "SHEETS",
      "id": "set-in-cloudflare-dashboard"
    }
  ]
}